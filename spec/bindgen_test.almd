// Tests for almide-bindgen
import json
import self as bindgen
import self.scaffolding as scaffolding

// ═══════════════════════════════════════════════════════
// Public API
// ═══════════════════════════════════════════════════════
test "version is not empty" {
  assert(string.len(bindgen.version()) > 0)
}

test "supported_languages has 21 entries" {
  assert_eq(list.len(bindgen.supported_languages()), 21)
}

// ═══════════════════════════════════════════════════════
// Shared helpers (mod.almd)
// ═══════════════════════════════════════════════════════
test "get_str returns value" {
  let obj = json.object([("name", json.from_string("hello"))]);
  assert_eq(bindgen.get_str(obj, "name"), "hello")
}

test "get_str returns empty for missing" {
  assert_eq(bindgen.get_str(json.object([]), "x"), "")
}

test "get_arr returns array" {
  let arr = json.array([json.from_int(1), json.from_int(2)]);
  let obj = json.object([("items", arr)]);
  assert_eq(list.len(bindgen.get_arr(obj, "items")), 2)
}

test "get_arr returns empty for missing" {
  assert_eq(list.len(bindgen.get_arr(json.object([]), "missing")), 0)
}

test "get_kind returns kind field" {
  let obj = json.object([("kind", json.from_string("record"))]);
  assert_eq(bindgen.get_kind(obj), "record")
}

test "get_type returns type field" {
  let ty = json.object([("kind", json.from_string("int"))]);
  let obj = json.object([("type", ty)]);
  let result = bindgen.get_type(obj);
  assert_eq(bindgen.get_kind(result), "int")
}

test "find_type_def finds by name" {
  let types = [
    json.parse('{"name":"A","kind":{"kind":"record","fields":[]}}') ?? json.null(),
    json.parse('{"name":"B","kind":{"kind":"variant","cases":[]}}') ?? json.null()
  ];
  assert_eq(bindgen.get_str(bindgen.find_type_def("B", types), "name"), "B")
}

test "find_type_def returns null for missing" {
  let types = [
    json.parse('{"name":"A","kind":{"kind":"record","fields":[]}}') ?? json.null()
  ];
  let result = bindgen.find_type_def("Z", types);
  assert_eq(bindgen.get_str(result, "name"), "")
}

test "is_record true" {
  let types = [
    json.parse('{"name":"P","kind":{"kind":"record","fields":[]}}') ?? json.null()
  ];
  assert_eq(bindgen.is_record("P", types), true)
}

test "is_record false" {
  let types = [
    json.parse('{"name":"S","kind":{"kind":"variant","cases":[]}}') ?? json.null()
  ];
  assert_eq(bindgen.is_record("S", types), false)
}

test "is_variant true" {
  let types = [
    json.parse('{"name":"S","kind":{"kind":"variant","cases":[]}}') ?? json.null()
  ];
  assert_eq(bindgen.is_variant("S", types), true)
}

// ═══════════════════════════════════════════════════════
// Scaffolding: gen_unpack
// ═══════════════════════════════════════════════════════
test "gen_unpack int" {
  let ty = json.parse('{"kind":"int"}') ?? json.null();
  let result = list.join(scaffolding.gen_unpack(ty, []), "\n");
  assert(string.contains(result, "read_i64_be"))
}

test "gen_unpack float" {
  let ty = json.parse('{"kind":"float"}') ?? json.null();
  let result = list.join(scaffolding.gen_unpack(ty, []), "\n");
  assert(string.contains(result, "read_f64_be"))
}

test "gen_unpack bool" {
  let ty = json.parse('{"kind":"bool"}') ?? json.null();
  let result = list.join(scaffolding.gen_unpack(ty, []), "\n");
  assert(string.contains(result, "read_bool"))
}

test "gen_unpack string" {
  let ty = json.parse('{"kind":"string"}') ?? json.null();
  let result = list.join(scaffolding.gen_unpack(ty, []), "\n");
  assert(string.contains(result, "read_string_be"))
}

test "gen_unpack named record" {
  let types = [
    json.parse('{"name":"Pt","kind":{"kind":"record","fields":[{"name":"x","type":{"kind":"int"}},{"name":"y","type":{"kind":"int"}}]}}') ?? json.null()
  ];
  let ty = json.parse('{"kind":"named","name":"Pt"}') ?? json.null();
  let result = list.join(scaffolding.gen_unpack(ty, types), "\n");
  assert(string.contains(result, "Pt {"));
  assert(string.contains(result, "x:"));
  assert(string.contains(result, "y:"))
}

test "gen_unpack named variant" {
  let types = [
    json.parse('{"name":"Color","kind":{"kind":"variant","cases":[{"name":"Red"},{"name":"Blue"}]}}') ?? json.null()
  ];
  let ty = json.parse('{"kind":"named","name":"Color"}') ?? json.null();
  let result = list.join(scaffolding.gen_unpack(ty, types), "\n");
  assert(string.contains(result, "match _tag"));
  assert(string.contains(result, "Red"));
  assert(string.contains(result, "Blue"))
}

// ═══════════════════════════════════════════════════════
// Scaffolding: gen_pack
// ═══════════════════════════════════════════════════════
test "gen_pack int" {
  let ty = json.parse('{"kind":"int"}') ?? json.null();
  let lines = scaffolding.gen_pack("n", ty, []);
  assert_eq(list.len(lines), 1);
  assert(string.contains(list.get(lines, 0) ?? "", "write_i64_be"))
}

test "gen_pack bool" {
  let ty = json.parse('{"kind":"bool"}') ?? json.null();
  let lines = scaffolding.gen_pack("flag", ty, []);
  assert(string.contains(list.get(lines, 0) ?? "", "flag"))
}

test "gen_pack string" {
  let ty = json.parse('{"kind":"string"}') ?? json.null();
  let lines = scaffolding.gen_pack("s", ty, []);
  assert_eq(list.len(lines), 1);
  assert(string.contains(list.get(lines, 0) ?? "", "write_string_be"))
}

test "gen_pack record" {
  let types = [
    json.parse('{"name":"Pt","kind":{"kind":"record","fields":[{"name":"x","type":{"kind":"int"}}]}}') ?? json.null()
  ];
  let ty = json.parse('{"kind":"named","name":"Pt"}') ?? json.null();
  let lines = scaffolding.gen_pack("p", ty, types);
  assert(list.len(lines) > 0);
  let joined = list.join(lines, " ");
  assert(string.contains(joined, "p.x"))
}

// ═══════════════════════════════════════════════════════
// Scaffolding: gen_scaffold_fn
// ═══════════════════════════════════════════════════════
test "gen_scaffold_fn produces extern C wrapper" {
  let f = json.parse('{"name":"add","params":[{"name":"a","type":{"kind":"int"}},{"name":"b","type":{"kind":"int"}}],"return":{"kind":"int"}}') ?? json.null();
  let text = list.join(scaffolding.gen_scaffold_fn(f, []), "\n");
  assert(string.contains(text, "@export(c"));
  assert(string.contains(text, "bridge_add"));
  assert(string.contains(text, "_p_a"));
  assert(string.contains(text, "_p_b"));
  assert(string.contains(text, "add(_p_a, _p_b)"))
}

test "gen_scaffold_fn string param" {
  let f = json.parse('{"name":"greet","params":[{"name":"name","type":{"kind":"string"}}],"return":{"kind":"string"}}') ?? json.null();
  let text = list.join(scaffolding.gen_scaffold_fn(f, []), "\n");
  assert(string.contains(text, "bridge_greet"));
  assert(string.contains(text, "read_string_be"))
}

// ═══════════════════════════════════════════════════════
// Scaffolding: gen_bridge_helpers
// ═══════════════════════════════════════════════════════
test "gen_bridge_helpers content" {
  let text = list.join(scaffolding.gen_bridge_helpers(), "\n");
  assert(string.contains(text, "bridge_alloc"));
  assert(string.contains(text, "bridge_free"))
}

// ═══════════════════════════════════════════════════════
// Scaffolding: full generate
// ═══════════════════════════════════════════════════════
test "generate empty interface" {
  let result = scaffolding.generate('{"module":"t","types":[],"functions":[]}');
  assert(string.contains(result, "bridge_alloc"));
  assert(string.contains(result, "AUTO-GENERATED"))
}

test "generate with function" {
  let iface = '{"module":"t","types":[],"functions":[{"name":"inc","params":[{"name":"n","type":{"kind":"int"}}],"return":{"kind":"int"}}]}';
  let result = scaffolding.generate(iface);
  assert(string.contains(result, "bridge_inc"))
}

test "generate_cargo" {
  let result = scaffolding.generate_cargo('{"module":"mylib","types":[],"functions":[]}');
  assert(string.contains(result, "[package]"));
  assert(string.contains(result, "cdylib"));
  assert(string.contains(result, "almide_mylib"))
}

test "generate with record type" {
  let iface = '{"module":"t","types":[{"name":"Pt","kind":{"kind":"record","fields":[{"name":"x","type":{"kind":"int"}}]}}],"functions":[{"name":"get_pt","params":[],"return":{"kind":"named","name":"Pt"}}]}';
  let result = scaffolding.generate(iface);
  assert(string.contains(result, "bridge_get_pt"))
}
